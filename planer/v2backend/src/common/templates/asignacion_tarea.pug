doctype html
html
  head
    meta(charset="UTF-8")
    style.
      body { margin: 0; padding: 0; font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif; background-color: #f1f5f9; }
      .wrapper { max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 12px; overflow: hidden; border: 1px solid #e2e8f0; }
      .header { background: linear-gradient(135deg, #e11d48, #be123c); padding: 24px 32px; text-align: center; }
      .header h1 { color: #ffffff; font-size: 22px; font-weight: 700; margin: 0; letter-spacing: -0.5px; }
      .header p { color: rgba(255,255,255,0.85); font-size: 13px; margin: 6px 0 0 0; }
      .body { padding: 32px; }
      .greeting { font-size: 16px; color: #0f172a; margin-bottom: 16px; }
      .greeting strong { color: #e11d48; }
      .card { background-color: #f8fafc; border: 1px solid #e2e8f0; border-left: 4px solid #e11d48; border-radius: 8px; padding: 20px; margin: 20px 0; }
      .card h3 { margin: 0 0 8px 0; font-size: 17px; color: #0f172a; }
      .card p { margin: 0; font-size: 14px; color: #475569; line-height: 1.5; }
      .meta { display: flex; margin-top: 16px; }
      .meta-item { margin-right: 24px; }
      .meta-label { font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: #94a3b8; font-weight: 700; }
      .meta-value { font-size: 14px; color: #0f172a; font-weight: 600; margin-top: 2px; }
      .cta-container { text-align: center; margin: 28px 0 12px 0; }
      .cta-btn { display: inline-block; background: linear-gradient(135deg, #e11d48, #be123c); color: #ffffff; padding: 14px 40px; text-decoration: none; border-radius: 8px; font-weight: 700; font-size: 14px; letter-spacing: 0.3px; }
      .footer { padding: 20px 32px; background-color: #f8fafc; text-align: center; border-top: 1px solid #e2e8f0; }
      .footer p { font-size: 11px; color: #94a3b8; margin: 0; line-height: 1.6; }
  body(style="margin:0; padding:20px 0; background-color:#f1f5f9;")
    table(width="100%" cellpadding="0" cellspacing="0" style="background-color:#f1f5f9;")
      tr
        td(align="center")
          .wrapper
            .header
              h1 📋 Planner-EF
              p Nueva tarea asignada

            .body
              p.greeting Hola <strong>#{nombre}</strong>,

              p(style="color:#475569; font-size:14px; line-height:1.6;")
                | <strong>#{asignadoPor}</strong> te ha asignado una nueva tarea. Revísala y comienza a trabajar en ella:

              .card
                h3 #{titulo}
                p #{descripcion}
                div(style="margin-top:16px;")
                  table(cellpadding="0" cellspacing="0")
                    tr
                      td(style="padding-right:24px;")
                        div(style="font-size:10px; text-transform:uppercase; letter-spacing:1px; color:#94a3b8; font-weight:700;") PRIORIDAD
                        div(style="font-size:14px; color:#0f172a; font-weight:600; margin-top:2px;") #{prioridad}
                      td(style="padding-right:24px;")
                        div(style="font-size:10px; text-transform:uppercase; letter-spacing:1px; color:#94a3b8; font-weight:700;") FECHA LÍMITE
                        div(style="font-size:14px; color:#0f172a; font-weight:600; margin-top:2px;") #{fechaLimite}
                      td
                        div(style="font-size:10px; text-transform:uppercase; letter-spacing:1px; color:#94a3b8; font-weight:700;") PROYECTO
                        div(style="font-size:14px; color:#0f172a; font-weight:600; margin-top:2px;") #{proyecto}

              .cta-container
                a.cta-btn(href="#{enlace}") Ver Tarea en Planner-EF

            .footer
              p Este es un mensaje automático de Planner-EF.
              p No respondas a este correo.

doctype html
html
  head
    meta(charset="UTF-8")
    style.
      body { margin: 0; padding: 0; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background-color: #fafafa; color: #111827; }
      .main { max-width: 600px; margin: 40px auto; background-color: #ffffff; border-radius: 8px; overflow: hidden; border: 1px solid #eeeeee; }
      .top-bar { background-color: #111827; height: 4px; }
      .header { padding: 40px 40px 20px 40px; }
      .logo { font-size: 20px; font-weight: 800; letter-spacing: -0.5px; color: #111827; display: flex; align-items: center; }
      .logo-icon { color: #ef4444; margin-right: 8px; }
      .content { padding: 0 40px 40px 40px; }
      .task-list { margin-top: 30px; }
      .task-item { padding: 20px 0; border-bottom: 1px solid #f3f4f6; }
      .task-item:last-child { border-bottom: none; }
      .task-name { font-size: 16px; font-weight: 600; color: #111827; margin-bottom: 8px; }
      .meta-group { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 10px; }
      .meta-tag { font-size: 12px; color: #6b7280; background-color: #f9fafb; padding: 2px 8px; border-radius: 4px; border: 1px solid #f3f4f6; }
      .meta-tag strong { color: #374151; }
      .status-pill { float: right; font-size: 11px; font-weight: 700; color: #ef4444; background-color: #fef2f2; padding: 4px 10px; border-radius: 12px; }
      .btn-wrap { margin-top: 40px; text-align: left; }
      .btn { background-color: #111827; color: #ffffff !important; padding: 12px 24px; border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 14px; transition: all 0.2s; }
      .footer { padding: 30px 40px; background-color: #f9fafb; border-top: 1px solid #eeeeee; font-size: 12px; color: #9ca3af; }
  body
    .main
      .top-bar
      .header
        .logo
          span.logo-icon ⬤
          | Planner-EF
        h2(style="font-size: 24px; margin-top: 20px; margin-bottom: 0;") Tareas pendientes de atención
        p(style="color: #6b7280; font-size: 14px; margin-top: 8px;") Informe matutino de seguimiento de agenda.
      
      .content
        p(style="font-size: 15px; line-height: 1.6;") Hola <strong>#{nombre}</strong>, se han identificado las siguientes tareas con retraso en tu flujo de trabajo:

        .task-list
          each tarea in tareas
            .task-item
              .status-pill #{tarea.diasAtraso}d atraso
              .task-name #{tarea.titulo}
              div(style="font-size: 13px; color: #6b7280;") 📁 #{tarea.proyecto}
              .meta-group
                .meta-tag
                  span De: 
                  strong #{tarea.creador}
                .meta-tag
                  span Para: 
                  strong #{tarea.asignado}
                .meta-tag
                  span Límite: 
                  strong #{tarea.fechaLimite}

        .btn-wrap
          a.btn(href=enlace) Abrir mi Agenda Personal

      .footer
        | © 2026 Sistema de Planificación Claridad v2. 
        br
        | Este es un mensaje automático, por favor no responda.

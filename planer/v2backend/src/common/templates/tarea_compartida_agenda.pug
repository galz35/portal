doctype html
html
  head
    meta(charset="UTF-8")
    style.
      body { margin: 0; padding: 0; font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif; background-color: #f1f5f9; }
      .wrapper { max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 12px; overflow: hidden; border: 1px solid #e2e8f0; }
  body(style="margin:0; padding:20px 0; background-color:#f1f5f9;")
    table(width="100%" cellpadding="0" cellspacing="0" style="background-color:#f1f5f9;")
      tr
        td(align="center")
          .wrapper
            //- HEADER
            div(style="background:linear-gradient(135deg,#2563eb,#1d4ed8); padding:24px 32px; text-align:center;")
              h1(style="color:#fff; font-size:22px; font-weight:700; margin:0; letter-spacing:-0.5px;") 📅 Planner-EF
              p(style="color:rgba(255,255,255,0.85); font-size:13px; margin:6px 0 0;") Tarea compartida en tu agenda

            //- BODY
            div(style="padding:32px;")
              p(style="font-size:16px; color:#0f172a; margin-bottom:16px;")
                | Hola <strong style="color:#2563eb;">#{nombre}</strong>,

              p(style="color:#475569; font-size:14px; line-height:1.6; margin-bottom:20px;")
                | <strong>#{compartidoPor}</strong> ha compartido una tarea en tu agenda para que la tengas presente:

              //- CARD DE LA TAREA
              div(style="background-color:#eff6ff; border:1px solid #bfdbfe; border-left:4px solid #2563eb; border-radius:8px; padding:20px; margin:20px 0;")
                div(style="font-size:17px; font-weight:700; color:#0f172a; margin-bottom:8px;") #{titulo}
                div(style="font-size:14px; color:#475569; line-height:1.5; margin-bottom:16px;") #{descripcion}
                table(cellpadding="0" cellspacing="0")
                  tr
                    td(style="padding-right:24px;")
                      div(style="font-size:10px; text-transform:uppercase; letter-spacing:1px; color:#94a3b8; font-weight:700;") FECHA
                      div(style="font-size:14px; color:#0f172a; font-weight:600; margin-top:2px;") #{fecha}
                    td
                      div(style="font-size:10px; text-transform:uppercase; letter-spacing:1px; color:#94a3b8; font-weight:700;") PROYECTO
                      div(style="font-size:14px; color:#0f172a; font-weight:600; margin-top:2px;") #{proyecto}

              //- CTA
              div(style="text-align:center; margin:28px 0 12px;")
                a(href="#{enlace}" style="display:inline-block; background:linear-gradient(135deg,#2563eb,#1d4ed8); color:#fff; padding:14px 40px; text-decoration:none; border-radius:8px; font-weight:700; font-size:14px;") Ver en Mi Agenda

            //- FOOTER
            div(style="padding:20px 32px; background-color:#f8fafc; text-align:center; border-top:1px solid #e2e8f0;")
              p(style="font-size:11px; color:#94a3b8; margin:0; line-height:1.6;") Este es un mensaje automático de Planner-EF.
              p(style="font-size:11px; color:#94a3b8; margin:0;") No respondas a este correo.

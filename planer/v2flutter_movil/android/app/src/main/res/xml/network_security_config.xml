<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Configuration para Momentus Mobile V2.

  Política: HTTPS obligatorio en producción.
  Solo se permite tráfico HTTP (cleartext) hacia:
    - 10.0.2.2 (localhost del host desde emulador Android)
    - localhost / 127.0.0.1 (desarrollo directo)

  Referencia: https://developer.android.com/training/articles/security-config
-->
<network-security-config>
    <!-- Dominio de producción: SOLO HTTPS -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">rhclaroni.com</domain>
    </domain-config>

    <!-- Desarrollo local: permitir HTTP solo a emulador/localhost -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>

    <!-- Por defecto: HTTPS obligatorio (bloquea HTTP a cualquier otro dominio) -->
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
